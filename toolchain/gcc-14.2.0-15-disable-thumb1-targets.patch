 MULTILIB_REQUIRED	+= mthumb/march=armv8-r/mfloat-abi=soft
@@ -72,7 +70,6 @@ MULTILIB_REQUIRED	+= mthumb/march=armv8-r+simd/mfloat-abi=softfp
 
 
